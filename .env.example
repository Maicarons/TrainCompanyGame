# 数据库配置
DATABASE_URL=mysql+pymysql://tcgame:tcgame_password@mysql:3306/tcgame

# Redis配置
REDIS_URL=redis://redis:6379/0

# 应用配置
APP_NAME=TrainCompanyGame
APP_ENV=development
DEBUG=True
SECRET_KEY=your_secret_key_here

# 游戏配置
GAME_TICK_INTERVAL=60  # 游戏时间流逝速度(秒)
MAP_SIZE=1000          # 地图大小
MAX_COMPANIES=100      # 最大公司数量

# 日志配置
LOG_LEVEL=INFO